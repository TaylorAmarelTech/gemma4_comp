{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Duecare safety harness — chat + classifier + GREP/RAG/Tools + per-tenant rollups + ILO indicator coverage. Anchored to the SLOs in docs/SLO.md.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Chat RPS (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(duecare_chat_requests_total[5m]))", "refId": "A"}
      ],
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "Chat error rate (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(duecare_chat_requests_total{status=~\"5..\"}[5m])) / sum(rate(duecare_chat_requests_total[5m]))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.005},
              {"color": "red", "value": 0.01}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0}
    },
    {
      "type": "stat",
      "title": "Chat p95 latency (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(duecare_chat_request_duration_seconds_bucket[5m])) by (le))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 8}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0}
    },
    {
      "type": "stat",
      "title": "Tokens/s out (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(duecare_model_tokens_out_total[5m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Chat latency p50 / p95 / p99",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(duecare_chat_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(duecare_chat_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(duecare_chat_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "type": "timeseries",
      "title": "Tokens out by tenant (24h sum)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (tenant) (increase(duecare_model_tokens_out_total[24h]))", "legendFormat": "{{tenant}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "type": "barchart",
      "title": "GREP rule hits (last 24h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (rule_id) (increase(duecare_grep_rule_hits_total[24h]))", "legendFormat": "{{rule_id}}", "refId": "A", "format": "table"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
    },
    {
      "type": "barchart",
      "title": "ILO indicator coverage (last 24h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (indicator) (increase(duecare_ilo_indicator_hits_total[24h]))", "legendFormat": "ILO #{{indicator}}", "refId": "A", "format": "table"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12}
    },
    {
      "type": "table",
      "title": "Top corridors queried (24h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "topk(10, sum by (corridor_code) (increase(duecare_corridor_lookups_total[24h])))", "refId": "A", "format": "table", "instant": true}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20}
    },
    {
      "type": "logs",
      "title": "Recent chat errors (Loki)",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "{job=\"duecare-chat\"} |= \"ERROR\" | json", "refId": "A"}
      ],
      "options": {"showTime": true, "wrapLogMessage": true, "sortOrder": "Descending"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["duecare", "harness"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Duecare overview",
  "uid": "duecare-overview",
  "version": 1
}
