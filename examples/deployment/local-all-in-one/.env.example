# Copy to .env and edit before `docker compose up`.

# --- Model ---
# Default: gemma4:e2b (Apache 2.0, ~1.5 GB INT8). Other options:
#   gemma4:e4b           — higher quality, ~3.5 GB
#   gemma4:e2b-instruct  — instruction-tuned variant
#   gemma3:1b            — fastest, ~600 MB
OLLAMA_MODEL=gemma4:e2b

# --- Networking ---
# Caddy listens on 80/443 by default. Change if you have a conflict.
HTTP_PORT=80
HTTPS_PORT=443

# --- Internet search (all optional) ---
# Pick ONE provider. Without any of them, Duecare falls back to
# DuckDuckGo HTML scraping (free, no key, but rate-limited and may
# break without notice).
#
# Tavily — designed for LLM agents, generous free tier
# https://app.tavily.com/sign-in
TAVILY_API_KEY=

# Brave Search — independent index, 2k queries/mo free
# https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=

# Serper — Google search wrapper, 2.5k queries free trial
# https://serper.dev
SERPER_API_KEY=
