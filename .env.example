# Duecare environment overrides for docker-compose.
#
# Copy to .env and edit:
#   cp .env.example .env
#
# Everything has a sensible default — .env is only needed if you
# want to change ports, model size, or enable optional features.

# ---- Service ports (host side) ----
# Override if 8080 / 8081 / 11434 are already bound on your machine.
# DUECARE_CHAT_PORT=8080
# DUECARE_CLASSIFIER_PORT=8081
# OLLAMA_PORT=11434
# DUECARE_DEV_PORT=8080         # used by docker-compose.dev.yml
# OLLAMA_DEV_PORT=11434         # used by docker-compose.dev.yml

# ---- Logging ----
# Levels: debug | info | warning | error
# DUECARE_LOG_LEVEL=info

# ---- Model selection ----
# Default: gemma4:e2b (Apache 2.0, ~1.5 GB INT8). Other options:
#   gemma4:e2b    ~1.5 GB  8 GB RAM   (default — recommended)
#   gemma4:e4b    ~3.5 GB  16 GB RAM  (higher quality)
#   gemma3:1b     ~600 MB  4 GB RAM   (fastest first-token latency)
#   gemma2:2b     ~1.5 GB  4 GB RAM   (legacy fallback if Gemma 4 not yet pulled)
#   gemma2:9b     ~5.4 GB  16 GB RAM  (legacy higher-quality fallback)
# DUECARE_OLLAMA_MODEL=gemma4:e2b

# ---- HuggingFace token (only needed for gated models pulled via
#       transformers — not needed for Ollama-pulled models) ----
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Internet search (optional) — pick ONE provider ----
# These are read by the duecare-llm-research-tools layer at runtime.
# The local docker-compose stack passes them through to the chat
# server so the worker can use the /research endpoint. Without any
# of these, the harness falls back to DuckDuckGo HTML scraping
# (rate-limited, no key, may break without notice).
#
# Tavily — recommended; LLM-agent-optimized; 1k queries/mo free
# https://app.tavily.com/sign-in
# TAVILY_API_KEY=

# Brave Search — independent index; 2k queries/mo free
# https://api.search.brave.com/app/keys
# BRAVE_SEARCH_API_KEY=

# Serper — Google wrapper; 2.5k free trial then $5/mo
# https://serper.dev
# SERPER_API_KEY=

# ---- OAuth2 / OIDC auth (used by docker-compose.auth.yml) ----
# Bring up with:
#   docker compose -f docker-compose.yml -f docker-compose.auth.yml up -d
# After login, oauth2-proxy injects X-Forwarded-User into upstream
# requests; Duecare's TenancyMiddleware uses that as the tenant id.
# AUTH_PORT=4180
# OAUTH2_PROVIDER=oidc                              # google | oidc | github | azure
# OAUTH2_OIDC_ISSUER_URL=https://accounts.google.com
# OAUTH2_CLIENT_ID=
# OAUTH2_CLIENT_SECRET=
# OAUTH2_COOKIE_SECRET=                             # openssl rand -base64 32 | tr -d '\n'
# OAUTH2_REDIRECT_URL=http://localhost:4180/oauth2/callback
# OAUTH2_EMAIL_DOMAINS=*                            # comma-separated; * = any
# OAUTH2_COOKIE_SECURE=false                        # set true behind HTTPS

# ---- Tenancy + rate limits ----
# Single-tenant default: requests with no tenant header get this id.
# DUECARE_DEFAULT_TENANT=public
# Per-tenant request-per-minute cap (token bucket).
# DUECARE_RATE_LIMIT_PER_MIN=60
# Per-tenant in-flight request cap.
# DUECARE_CONCURRENCY_PER_TENANT=10

# ---- OpenTelemetry tracing (engine) ----
# DUECARE_OTEL_ENABLED=false
# DUECARE_OTEL_ENDPOINT=http://otel-collector:4318
# DUECARE_OTEL_PROTOCOL=http/protobuf                # http/protobuf | grpc
# DUECARE_OTEL_SERVICE_NAME=duecare-engine
# DUECARE_OTEL_ENV=local

# ---- Cost lookup override (optional) ----
# Point at a JSON file with per-model {"in": $/1k, "out": $/1k} entries
# to override the bundled defaults at duecare-llm-server's metering.py
# DUECARE_MODEL_COSTS_FILE=/etc/duecare/model_costs.json
