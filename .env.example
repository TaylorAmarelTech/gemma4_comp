# Duecare environment overrides for docker-compose.
#
# Copy to .env and edit:
#   cp .env.example .env
#
# Everything has a sensible default — .env is only needed if you
# want to change ports, model size, or enable optional features.

# ---- Service ports ----
# DUECARE_CHAT_PORT=8080
# DUECARE_CLASSIFIER_PORT=8081
# OLLAMA_PORT=11434

# ---- Logging ----
# Levels: debug | info | warning | error
# DUECARE_LOG_LEVEL=info

# ---- Model selection ----
# Ollama model tag. Smaller = faster + less RAM; larger = better quality.
#   gemma2:2b    ~1.5 GB  4 GB RAM     (default — works everywhere)
#   gemma2:9b    ~5.4 GB  8 GB RAM
#   gemma2:27b  ~16 GB    32 GB RAM
# When Gemma 4 lands in Ollama stable: gemma4:e2b / gemma4:e4b / gemma4:31b
# DUECARE_OLLAMA_MODEL=gemma2:2b

# ---- HuggingFace token (only needed for gated models like Gemma 4
#       directly via transformers; not needed for Ollama-pulled models) ----
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- BYOK keys for the agentic-research notebook (A4) ----
# These are NOT used by the local docker-compose stack — the
# agentic-research surface is a Kaggle notebook only.
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# SERPER_API_KEY=
